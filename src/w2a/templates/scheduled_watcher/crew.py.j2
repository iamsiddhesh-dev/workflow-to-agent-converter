"""Generated by w2a — scheduled_watcher pattern for "{{ workflow.name }}".

Tasks structurally disconnected from the poll trigger (no deps, no dependents,
no flow edge — the spec linter flags these as ``orphan_task``) are almost
always on a *different* cadence than the per-poll watch chain: a "generate the
weekly report" task next to a "classify this ticket" task doesn't mean "run
the weekly report on every ticket poll," it means the workflow actually has two
schedules. Those tasks are split into a second crew (``run_periodic``) that
``main.py`` only runs behind ``--periodic``, so the poll loop
(``run_once``, called every ``--interval`` seconds) never re-triggers them.
{% if periodic_tasks %}This project has {{ periodic_tasks | length }}: {{ periodic_tasks | map(attribute='id') | join(', ') }}.{% else %}This workflow has none — every task is part of the poll chain.{% endif %}
"""

from __future__ import annotations

from crewai import Agent, Crew, Process, Task

{% if has_human_checkpoint %}
from config import MOCK_MODE, build_llm
{% else %}
from config import build_llm
{% endif %}
{% if tools %}
from tools import ALL_TOOLS
{% endif %}

_llm = build_llm()

{{ m.agents_block(agents, tools | length > 0) }}

{% for t in tasks %}
{{ t.var }} = Task(
{{ m.task_kwargs(t) -}}
)
{% endfor %}


def build_crew() -> Crew:
    """The per-poll watch chain: tasks connected to the recurring trigger."""
    return Crew(
        agents=[{{ agents | map(attribute='var') | join(', ') }}],
        tasks=[{{ watch_tasks | map(attribute='var') | join(', ') }}],
        process=Process.sequential,
        verbose=True,
    )


def run_once(inputs: dict | None = None):
    """Execute one poll -> detect -> notify pass. Called in a loop by main.py."""
    crew = build_crew()
    return crew.kickoff(inputs=inputs or {})
{% if periodic_tasks %}

def build_periodic_crew() -> Crew:
    """Tasks on their own cadence (e.g. a weekly report), disconnected from the poll chain."""
    return Crew(
        agents=[{{ agents | map(attribute='var') | join(', ') }}],
        tasks=[{{ periodic_tasks | map(attribute='var') | join(', ') }}],
        process=Process.sequential,
        verbose=True,
    )


def run_periodic(inputs: dict | None = None):
    """Run the periodic (non-per-poll) tasks once. Wire this to an external cron/schedule."""
    crew = build_periodic_crew()
    return crew.kickoff(inputs=inputs or {})
{% endif %}
