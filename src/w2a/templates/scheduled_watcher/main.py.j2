{% set watch_tasks = tasks | rejectattr('is_periodic') | list %}
{% set periodic_tasks = tasks | selectattr('is_periodic') | list %}
"""Generated by w2a — entrypoint for "{{ workflow.name }}" (scheduled_watcher).

Trigger: {{ workflow.trigger }}

`python main.py` polls the watch chain every --interval seconds.
{% if periodic_tasks %}`python main.py --periodic` runs the periodic tasks ({{ periodic_tasks | map(attribute='id') | join(', ') }})
once and exits — point an external cron/scheduler at this flag instead of
letting them re-fire on every poll pass.{% endif %}
"""

from __future__ import annotations

import argparse
import sys
import time
from pathlib import Path

try:
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")
except (AttributeError, ValueError):
    pass  # stdout/stderr isn't reconfigurable (e.g. piped through something that already sets encoding)

from crew import run_once, {% if periodic_tasks %}run_periodic, {% endif %}{{ tasks | map(attribute='var') | join(', ') }}

_WATCH_TASK_IDS = [{% for t in watch_tasks %}{{ t.id | pyrepr }}, {% endfor %}]
_PERIODIC_TASK_IDS = [{% for t in periodic_tasks %}{{ t.id | pyrepr }}, {% endfor %}]
_TASK_VARS = {
{% for t in tasks %}
    {{ t.id | pyrepr }}: {{ t.var }},
{% endfor %}
}


def _log(event: str, task_id: str) -> None:
    print(f"[w2a] {event} task={task_id}", flush=True)


def _wire_callbacks() -> None:
    for task_id, task in _TASK_VARS.items():
        task.callback = lambda output, _id=task_id: _log("TASK_END", _id)


def _read_input(source: str) -> str:
    if source == "-":
        return sys.stdin.read()
    return Path(source).read_text(encoding="utf-8")


def _print_task_outputs(task_ids: list[str]) -> None:
    print("\n--- TASK OUTPUTS ---")
    for task_id in task_ids:
        output = getattr(_TASK_VARS[task_id], "output", None)
        if output is None:
            print(f"[{task_id}] (skipped — no output)")
        else:
            print(f"[{task_id}]\n{output.raw}\n")


def main() -> int:
    parser = argparse.ArgumentParser(description={{ workflow.description | pyrepr }})
    parser.add_argument("input", nargs="?", default="-", help="Input file, or '-' for stdin.")
    parser.add_argument("--once", action="store_true", help="Run a single poll pass and exit.")
    parser.add_argument("--interval", type=float, default=60.0, help="Seconds between polls.")
    parser.add_argument(
        "--periodic", action="store_true",
        help="Run only the periodic tasks (disconnected from the poll chain) once and exit.",
    )
    args = parser.parse_args()

    payload = _read_input(args.input)
    _wire_callbacks()

    if args.periodic:
{% if periodic_tasks %}
        for task_id in _PERIODIC_TASK_IDS:
            _log("TASK_START", task_id)
        result = run_periodic(inputs={"input": payload})
        _print_task_outputs(_PERIODIC_TASK_IDS)
        print("\n--- RESULT ---")
        print(result.raw)
{% else %}
        print("[w2a] this workflow has no periodic tasks — nothing to run.")
{% endif %}
        return 0

    while True:
        for task_id in _WATCH_TASK_IDS:
            _log("TASK_START", task_id)
        result = run_once(inputs={"input": payload})
        _print_task_outputs(_WATCH_TASK_IDS)
        print("\n--- RESULT ---")
        print(result.raw)
        if args.once:
            return 0
        time.sleep(args.interval)


if __name__ == "__main__":
    raise SystemExit(main())
