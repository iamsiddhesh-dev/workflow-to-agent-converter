{% import "_common/macros.j2" as m %}
"""Generated by w2a — report_generator pattern for "{{ workflow.name }}".

Independent gather tasks (no depends_on) run first; the final task(s) — the
ones nothing else depends on — aggregate their context and write the report
artifact to output/.
"""

from __future__ import annotations

from crewai import Agent, Crew, Process, Task

from config import build_llm

_llm = build_llm()

{{ m.agents_block(agents) }}

{% for t in tasks %}
{{ t.var }} = Task(
{{ m.task_kwargs(t) -}}
{% if t.is_leaf %}
    output_file="output/{{ workflow.slug }}_{{ t.id }}.md",
    create_directory=True,
{% endif %}
)
{% endfor %}


def build_crew() -> Crew:
    return Crew(
        agents=[{{ agents | map(attribute='var') | join(', ') }}],
        tasks=[{{ tasks | map(attribute='var') | join(', ') }}],
        process=Process.sequential,
        verbose=True,
    )
