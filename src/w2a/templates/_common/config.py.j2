"""Generated by w2a — LLM wiring for "{{ workflow.name }}".

Set MOCK_MODE=1 to run without any API key or network call: every agent gets
a MockLLM that returns a canned, schema-shaped response, and tool stubs (see
tools.py) return their canned payload too. Unset (or 0) runs for real against
Gemini (primary), matching src/w2a/llm.py's provider choice.
"""

from __future__ import annotations

import os

from crewai import LLM
from crewai.llms.base_llm import BaseLLM

MOCK_MODE = os.environ.get("MOCK_MODE", "0") == "1"


class MockLLM(BaseLLM):
    """Canned, schema-shaped responses — zero-cost dry runs, no network."""

    def __init__(self, **kwargs) -> None:
        super().__init__(model="mock/mock-llm", **kwargs)

    def call(
        self,
        messages,
        tools=None,
        callbacks=None,
        available_functions=None,
        from_task=None,
        from_agent=None,
        response_model=None,
    ):
        return "MOCK_OUTPUT: canned response for offline validation."

    def supports_function_calling(self) -> bool:
        return False


def build_llm():
    if MOCK_MODE:
        return MockLLM()
    return LLM(
        model=f"gemini/{os.environ.get('W2A_GEMINI_MODEL', 'gemini-flash-lite-latest')}",
        api_key=os.environ.get("GEMINI_API_KEY", ""),
        temperature=0.3,
    )
