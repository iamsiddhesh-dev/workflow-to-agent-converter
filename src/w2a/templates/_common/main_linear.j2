"""Generated by w2a — entrypoint for "{{ workflow.name }}" ({{ pattern }}).

Trigger: {{ workflow.trigger }}
"""

from __future__ import annotations

import sys
from pathlib import Path

try:
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")
except (AttributeError, ValueError):
    pass  # stdout/stderr isn't reconfigurable (e.g. piped through something that already sets encoding)

from crew import build_crew, {{ tasks | map(attribute='var') | join(', ') }}

_TASK_IDS = [{% for t in tasks %}{{ t.id | pyrepr }}, {% endfor %}]
_TASK_VARS = {
{% for t in tasks %}
    {{ t.id | pyrepr }}: {{ t.var }},
{% endfor %}
}


def _log(event: str, task_id: str) -> None:
    print(f"[w2a] {event} task={task_id}", flush=True)


def _wire_callbacks() -> None:
    for task_id, task in _TASK_VARS.items():
        task.callback = lambda output, _id=task_id: _log("TASK_END", _id)


def _read_input(source: str) -> str:
    if source == "-":
        return sys.stdin.read()
    return Path(source).read_text(encoding="utf-8")


def _print_task_outputs() -> None:
    print("\n--- TASK OUTPUTS ---")
    for task_id in _TASK_IDS:
        output = getattr(_TASK_VARS[task_id], "output", None)
        if output is None:
            print(f"[{task_id}] (skipped — no output)")
        else:
            print(f"[{task_id}]\n{output.raw}\n")


def main() -> int:
    source = sys.argv[1] if len(sys.argv) > 1 else "-"
    payload = _read_input(source)

    _wire_callbacks()
    for task_id in _TASK_IDS:
        _log("TASK_START", task_id)

    crew = build_crew()
    result = crew.kickoff(inputs={"input": payload})

    _print_task_outputs()

    print("\n--- RESULT ---")
    print(result.raw)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
