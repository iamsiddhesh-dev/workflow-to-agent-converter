"""Generated by w2a — triage_router pattern for "{{ workflow.name }}".

Root task(s) classify the input. Every downstream task is a CrewAI
ConditionalTask: it only executes when its own domain keywords (drawn from
the spec's own task description/expected_output — never invented) show up in
the classifier's output. This keeps the branch-vs-no-branch decision inside
CrewAI's native conditional-task mechanism instead of hand-rolled if/else.
"""

from __future__ import annotations

from crewai import Agent, Crew, Process, Task
from crewai.tasks.conditional_task import ConditionalTask
from crewai.tasks.task_output import TaskOutput

from config import build_llm

_llm = build_llm()

{{ m.agents_block(agents) }}

def _matches(keywords):
    """Condition factory: true if any keyword shows up in the upstream task's raw output."""

    def _condition(output: TaskOutput) -> bool:
        if not keywords:
            return True
        text = (output.raw or "").lower()
        return any(k in text for k in keywords)

    return _condition

{% for t in tasks %}
{% if t.is_root %}
{{ t.var }} = Task(
{{ m.task_kwargs(t) -}}
)
{% else %}
{{ t.var }} = ConditionalTask(
{{ m.task_kwargs(t) -}}
    condition=_matches({{ t.condition_keywords | pyrepr }}),
)
{% endif %}
{% endfor %}


def build_crew() -> Crew:
    return Crew(
        agents=[{{ agents | map(attribute='var') | join(', ') }}],
        tasks=[{{ tasks | map(attribute='var') | join(', ') }}],
        process=Process.sequential,
        verbose=True,
    )
